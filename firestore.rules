rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userPath(uid) { return /databases/$(database)/documents/users/$(uid); }
    function codePath(id) { return /databases/$(database)/documents/activationCodes/$(id); }
    function me() { return get(userPath(request.auth.uid)).data; }
    function role(r) { return signedIn() && me().aktif != false && me().role == r; }
    function validRole(r) { return r in ['admin', 'pengawas', 'kamad', 'guru']; }
    function registrableRole(r) { return r in ['pengawas', 'kamad', 'guru']; }
    function validScope(d) {
      return ((d.role in ['guru', 'kamad']) && d.madrasahId is string && d.madrasahId.size() > 0 && d.madrasahBinaanIds is list && d.madrasahBinaanIds.size() == 0)
        || (d.role == 'pengawas' && d.madrasahId == '' && d.madrasahBinaanIds is list && d.madrasahBinaanIds.size() > 0);
    }
    function canAccess(d) {
      return role('admin') || (role('guru') && d.ownerId == request.auth.uid)
        || (role('kamad') && d.madrasahId == me().madrasahId)
        || (role('pengawas') && d.madrasahId in me().madrasahBinaanIds);
    }
    function tenantFieldsValid(d) { return d.ownerId is string && d.madrasahId is string; }
    function validActivationCreate(uid) {
      let c = get(codePath(request.resource.data.activationCodeId)).data;
      return request.auth.uid == uid && registrableRole(request.resource.data.role)
        && request.resource.data.keys().hasAll(['email','nama','role','madrasahId','madrasahBinaanIds','aktif','activationCodeId'])
        && request.resource.data.aktif == true && validScope(request.resource.data)
        && c.active == true && c.used == false && c.expiresAt > request.time
        && (c.email == '' || c.email == request.auth.token.email)
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == c.role
        && request.resource.data.madrasahId == c.madrasahId
        && request.resource.data.madrasahBinaanIds == c.madrasahBinaanIds
        && getAfter(codePath(request.resource.data.activationCodeId)).data.used == true
        && getAfter(codePath(request.resource.data.activationCodeId)).data.usedBy == uid;
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || role('admin'));
      allow create: if (role('admin') && validRole(request.resource.data.role)) || validActivationCreate(uid);
      allow delete: if role('admin');
      allow update: if (role('admin') && validRole(request.resource.data.role))
        || (request.auth.uid == uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nama','photoURL','updatedAt'])
          && request.resource.data.role == resource.data.role && request.resource.data.madrasahId == resource.data.madrasahId
          && request.resource.data.madrasahBinaanIds == resource.data.madrasahBinaanIds);
    }

    match /activationCodes/{codeId} {
      allow read, create, delete: if role('admin');
      allow update: if role('admin') || (signedIn() && resource.data.active == true && resource.data.used == false
        && resource.data.expiresAt > request.time && (resource.data.email == '' || resource.data.email == request.auth.token.email)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used','usedBy','usedAt'])
        && request.resource.data.used == true && request.resource.data.usedBy == request.auth.uid
        && getAfter(userPath(request.auth.uid)).data.activationCodeId == codeId);
    }

    // Master Data rules must stay before the wildcard. Guru has no Master Data access.
    match /madrasah/{id} {
      allow read: if role('admin') || (role('kamad') && id == me().madrasahId)
        || (role('pengawas') && id in me().madrasahBinaanIds);
      allow write: if role('admin');
    }
    match /guru/{id} {
      allow read: if role('admin') || (role('kamad') && resource.data.madrasahId == me().madrasahId)
        || (role('pengawas') && resource.data.madrasahId in me().madrasahBinaanIds);
      allow create: if role('admin') || (role('kamad') && tenantFieldsValid(request.resource.data)
        && request.resource.data.madrasahId == me().madrasahId);
      allow update: if role('admin') || (role('kamad') && resource.data.madrasahId == me().madrasahId
        && request.resource.data.madrasahId == me().madrasahId
        && request.resource.data.ownerId == resource.data.ownerId);
      allow delete: if role('admin') || (role('kamad') && resource.data.madrasahId == me().madrasahId);
    }
    match /kelas/{id} {
      allow read: if role('admin') || (role('kamad') && resource.data.madrasahId == me().madrasahId)
        || (role('pengawas') && resource.data.madrasahId in me().madrasahBinaanIds);
      allow create: if role('admin') || (role('kamad') && tenantFieldsValid(request.resource.data)
        && request.resource.data.madrasahId == me().madrasahId);
      allow update: if role('admin') || (role('kamad') && resource.data.madrasahId == me().madrasahId
        && request.resource.data.madrasahId == me().madrasahId
        && request.resource.data.ownerId == resource.data.ownerId);
      allow delete: if role('admin') || (role('kamad') && resource.data.madrasahId == me().madrasahId);
    }
    match /murid/{id} {
      allow read: if role('admin') || (role('kamad') && resource.data.madrasahId == me().madrasahId)
        || (role('pengawas') && resource.data.madrasahId in me().madrasahBinaanIds);
      allow create: if role('admin') || (role('kamad') && tenantFieldsValid(request.resource.data)
        && request.resource.data.madrasahId == me().madrasahId);
      allow update: if role('admin') || (role('kamad') && resource.data.madrasahId == me().madrasahId
        && request.resource.data.madrasahId == me().madrasahId
        && request.resource.data.ownerId == resource.data.ownerId);
      allow delete: if role('admin') || (role('kamad') && resource.data.madrasahId == me().madrasahId);
    }
    match /indikatorPancaCinta/{id} {
      allow read: if role('admin') || role('kamad') || role('pengawas');
      allow write: if role('admin');
    }
    match /{collectionName}/{documentId} {
      // Named Master Data matches are OR'ed with wildcards by Firestore. Exclude
      // them here so the general record RBAC cannot accidentally grant access.
      allow read, delete: if !(collectionName in ['madrasah','guru','kelas','murid','indikatorPancaCinta'])
        && signedIn() && canAccess(resource.data);
      allow create: if !(collectionName in ['madrasah','guru','kelas','murid','indikatorPancaCinta'])
        && signedIn() && tenantFieldsValid(request.resource.data) && canAccess(request.resource.data);
      allow update: if !(collectionName in ['madrasah','guru','kelas','murid','indikatorPancaCinta'])
        && signedIn() && tenantFieldsValid(request.resource.data) && canAccess(resource.data) && canAccess(request.resource.data)
        && request.resource.data.ownerId == resource.data.ownerId && request.resource.data.madrasahId == resource.data.madrasahId;
    }
  }
}
